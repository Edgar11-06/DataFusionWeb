@model List<DataFusionArenaWeb.Models.DataItem>
@{
    ViewData["Title"] = "Datos";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
    string selectedCategoria = ViewBag.SelectedCategoria as string ?? "(Todos)";
    string selectedSort = ViewBag.SelectedSort as string ?? "Original";
    bool isSqlConfigured = ViewBag.IsSqlConfigured as bool? ?? false;
    string connStr = ViewBag.ConnectionString as string ?? string.Empty;
}
<div class="container py-3">
    <h2>Datos</h2>

    @if (!string.IsNullOrEmpty(ViewBag.Message as string))
    {
        <div class="alert alert-success">@ViewBag.Message</div>
    }
    @if (!string.IsNullOrEmpty(ViewBag.Error as string))
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-action="Upload" asp-controller="Items" enctype="multipart/form-data" method="post" class="mb-3 d-flex gap-2">
        <input type="file" name="file" class="form-control" />
        <button class="btn btn-primary" type="submit">Subir</button>

        <select id="categoria" name="categoria" class="form-select w-auto ms-2" onchange="onFilterChange()">
            @foreach (var c in categorias)
            {
                <option value="@c" selected="@(c == selectedCategoria ? "selected" : null)">@c</option>
            }
        </select>

        <select id="sort" name="sort" class="form-select w-auto ms-2" onchange="onFilterChange()">
            <option value="Original" selected="@(selectedSort?.Contains("Original") == true ? "selected" : null)">Orden original</option>
            <option value="Mayor" selected="@(selectedSort?.Contains("Mayor") == true ? "selected" : null)">Mayor a menor</option>
            <option value="Menor" selected="@(selectedSort?.Contains("Menor") == true ? "selected" : null)">Menor a mayor</option>
        </select>

        <div class="btn-group ms-2">
            <a asp-action="Export" asp-route-format="csv" class="btn btn-outline-secondary">CSV</a>
            <a asp-action="Export" asp-route-format="json" class="btn btn-outline-secondary">JSON</a>
            <a asp-action="Export" asp-route-format="xlsx" class="btn btn-outline-secondary">Excel</a>
        </div>
    </form>

    <div class="mb-3 d-flex gap-2 align-items-center">
        @* Enlace a la página Razor para configurar la conexión *@
        <a href="/Connection" class="btn btn-outline-info me-2">Configurar conexión</a>

        @* Formulario independiente para migrar a SQL (ya no está dentro del form de Upload) *@
        <form asp-action="MigrateToSql" asp-controller="Items" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Migrar a SQL</button>
        </form>
    </div>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Categoria</th>
                <th class="text-end">Cantidad</th>
                <th class="text-end">PrecioUnitario</th>
                <th class="text-end">Valor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var it in Model)
            {
                <tr>
                    <td>@it.Id</td>
                    <td>@it.Nombre</td>
                    <td>@it.Categoria</td>
                    <td class="text-end">@it.Cantidad</td>
                    <td class="text-end">@it.PrecioUnitario.ToString("N2")</td>
                    <td class="text-end">@it.Valor.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function onFilterChange() {
            const cat = document.getElementById('categoria').value;
            const sort = document.getElementById('sort').value;
            const url = new URL(window.location.href);
            url.searchParams.set('categoria', cat);
            url.searchParams.set('sort', sort);
            window.location.href = url.toString();
        }
    </script>
}
